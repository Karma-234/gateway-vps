# === Sensitive / Secret files ===
secrets/
*.key
*.pem
*.p12
*.pfx
.env
.env.*
credentials.json
service-account.json

# === Git & Version Control ===
.git
.gitignore
.gitattributes

# === Build artifacts & caches ===
**/target/
**/bin/
**/obj/
**/build/
**/dist/
*.exe
*.dll
*.so
*.dylib

# === Go specific ===
go.sum.bak
vendor/                  
*.test
*.prof

# === Logs & temporary files ===
*.log
logs/
tmp/
temp/
*.tmp

# === Development & testing ===
.dockerignore
README.md
LICENSE
*.md
test/
tests/
**/testdata/
**/mocks/
